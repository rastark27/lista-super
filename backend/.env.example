# Puerto del servidor (Render lo asigna automáticamente en producción)
PORT=3000
NODE_ENV=development

# Token secreto que el frontend debe mandar en el header X-API-Key.
# Generalo con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=cambiame_por_un_token_largo_aleatorio

# Lista de orígenes permitidos por CORS, separados por coma.
# En desarrollo local podés dejarlo vacío.
# En producción: ALLOWED_ORIGINS=https://tu-frontend.onrender.com
ALLOWED_ORIGINS=

# Credenciales de MySQL en Railway (las copiás desde el panel de Railway)
MYSQLHOST=
MYSQLUSER=
MYSQLPASSWORD=
MYSQLDATABASE=
MYSQLPORT=3306
